# =============================================================================
# Variables de entorno · Velo
# Copia este archivo a .env.local y rellena los valores de tu proyecto Supabase.
# (Dashboard → Project Settings → API)
# =============================================================================

# Públicas (van en el navegador, NO son secretas)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# SECRETA · solo servidor · NUNCA la subas al repo ni la expongas al cliente.
# La usan los endpoints del portal público de reservas (/api/reservar/...).
# En producción (Vercel) añádela como variable de entorno del proyecto.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Rate limiting distribuido (opcional). Si faltan, se usa un límite en memoria.
# Crear en https://upstash.com → Redis → sección REST API. Son secretas.
UPSTASH_REDIS_REST_URL=https://TU-BASE.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu-token-de-upstash

# Captcha anti-bot Cloudflare Turnstile (opcional). Pon LAS DOS o NINGUNA.
# Crear en https://dash.cloudflare.com → Turnstile → Add site.
# La SITE_KEY es pública (va en el navegador); la SECRET_KEY es secreta (servidor).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=tu-site-key
TURNSTILE_SECRET_KEY=tu-secret-key

# Stripe (suscripción 30€/mes). Si faltan, los pagos quedan desactivados.
# Claves en https://dashboard.stripe.com → Developers → API keys (son secretas).
STRIPE_SECRET_KEY=sk_live_o_test_...
# Price ID del plan recurrente de 30€/mes (Productos → tu plan → Pricing).
STRIPE_PRICE_ID=price_...
# Secreto del webhook (Developers → Webhooks → tu endpoint → Signing secret).
STRIPE_WEBHOOK_SECRET=whsec_...
# URL pública de la app (para los enlaces de retorno de Stripe).
NEXT_PUBLIC_APP_URL=https://velosaas.vercel.app
